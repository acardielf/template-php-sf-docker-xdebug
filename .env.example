###> Symfony ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string
###< Symfony ###

###> Database — PostgreSQL (always) ###
DATABASE_URL="postgresql://app:secret@postgres:5432/app?serverVersion=16&charset=utf8"
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432
###< Database ###

###> Redis / Messenger ###
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
REDIS_PORT=6379
###< Redis / Messenger ###

###> Mailer ###
MAILER_DSN=smtp://mailpit:1025
MAILER_SENDER_EMAIL=noreply@example.com
MAILER_SENDER_NAME="My Application"
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
###< Mailer ###

###> Nginx ###
NGINX_PORT=8080
###< Nginx ###

###> SonarQube ###
SONARQUBE_PORT=9000
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=change_me_to_your_sonarqube_token
SONAR_PROJECT_KEY=php-sf-template
###< SonarQube ###
